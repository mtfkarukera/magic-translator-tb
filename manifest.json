{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "2.0.3",
  "description": "__MSG_extDescription__",
  "author": "MTF Karukera",
  "default_locale": "fr",
  "browser_specific_settings": {
    "gecko": {
      "id": "magic-translator@mtfkarukera.net",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "message_display_action": {
    "default_icon": {
      "128": "icon.png"
    },
    "default_title": "Magic Translator",
    "default_popup": null
  },
  "permissions": [
    "scripting",
    "messagesRead",
    "storage",
    "menus"
  ],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ]
}
